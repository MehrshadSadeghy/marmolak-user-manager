# Copy to .env:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
RAYA_TRADE_ENVIRONMENT=docker
API_PORT=8080

# Public URL embedded in V2Ray subscription links
SUBSCRIPTION_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# PostgreSQL — compose creates DB/user on first start from these values
# If you change POSTGRES_PASSWORD after the first run, reset the volume:
#   docker compose down -v && docker compose up --build
# ---------------------------------------------------------------------------
POSTGRES_DB=user_manager_db
POSTGRES_USER=user_manager_user
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_HOST_PORT=5432

# ---------------------------------------------------------------------------
# Telegram bot (from @BotFather)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Legacy alias for ADMIN_CHAT_IDS (merged at runtime)
TELEGRAM_ADMIN_IDS=

# Comma-separated Telegram chat IDs allowed to use admin panel actions
ADMIN_CHAT_IDS=
SUPER_ADMIN_CHAT_IDS=

# Protects billing HTTP routes when the bot calls the API
BOT_API_KEY=changeme-bot-api-key

# Shown to users before they upload a payment receipt
PAYMENT_INSTRUCTIONS=

# Bot worker API target (defaults to local API)
USER_MANAGER_API_URL=http://127.0.0.1:8080

# ---------------------------------------------------------------------------
# Logging — database/Neo4j/SQLAlchemy noise is suppressed in the app
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# Set to 1 to log every HTTP request line from uvicorn
UVICORN_ACCESS_LOG=0

# ---------------------------------------------------------------------------
# PasarGuard panel integration (optional)
# Set PASARGUARD_PANEL_URL to your panel base URL, e.g. https://panel.example.com
# ---------------------------------------------------------------------------
PASARGUARD_PANEL_URL=
PASARGUARD_SUBSCRIPTION_PATH=sub
# Optional HTTPS URL opened by "افزودن پنل پاسارگارد" WebApp button (defaults to panel URL)
PASARGUARD_PANEL_WEBAPP_URL=

# ---------------------------------------------------------------------------
# OpenVPN authentication mode (Phase 0 — certificate keeps current behavior)
# certificate | dual | user_pass
# ---------------------------------------------------------------------------
OPENVPN_AUTH_MODE=certificate
# Phase 6 rollout: set OPENVPN_AUTH_MODE=dual on both user-manager and openvpn-node.
# New purchases automatically get user_pass credentials; existing DB rows stay certificate.
# Override new-user mode explicitly if needed: OPENVPN_PROVISIONING_AUTH_MODE=user_pass
# OPENVPN_PROVISIONING_AUTH_MODE=user_pass
# When true and auth mode is dual/user_pass, user-manager asks openvpn-node to patch server.conf
OPENVPN_AUTO_APPLY_SERVER_AUTH=false
# Phase 7: allow legacy certificate users to opt in to username/password (requires server dual mode)
OPENVPN_LEGACY_MIGRATION_ENABLED=false
# Days after opt-in before user can remove the old certificate profile (0 = immediate)
OPENVPN_LEGACY_MIGRATION_GRACE_DAYS=7
# Phase 8: when server and provisioning use user_pass, new users get auth-only profiles (no per-user cert)
# Set OPENVPN_AUTH_MODE=user_pass on both user-manager and openvpn-node once legacy cert clients are gone

# ---------------------------------------------------------------------------
# Traffic accounting sync (OpenVPN status + disconnect hooks)
# ---------------------------------------------------------------------------
TRAFFIC_ENFORCEMENT_ENABLED=true
TRAFFIC_ENFORCEMENT_INTERVAL_SECONDS=60
