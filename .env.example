# Copy to .env:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
RAYA_TRADE_ENVIRONMENT=docker
API_PORT=8080

# Public URL embedded in V2Ray subscription links
SUBSCRIPTION_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# PostgreSQL — compose creates DB/user on first start from these values
# If you change POSTGRES_PASSWORD after the first run, reset the volume:
#   docker compose down -v && docker compose up --build
# ---------------------------------------------------------------------------
POSTGRES_DB=user_manager_db
POSTGRES_USER=user_manager_user
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_HOST_PORT=5432

# ---------------------------------------------------------------------------
# Telegram bot (from @BotFather)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Comma-separated Telegram chat IDs allowed to use admin panel actions
ADMIN_CHAT_IDS=
SUPER_ADMIN_CHAT_IDS=

# Protects billing HTTP routes when the bot calls the API
BOT_API_KEY=changeme-bot-api-key

# Shown to users before they upload a payment receipt
PAYMENT_INSTRUCTIONS=
